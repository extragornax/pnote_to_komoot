{
  "manifest_version": 2,
  "name": "Pnote Invaders on Komoot",
  "version": "1.0.0",
  "description": "Overlay Space Invader locations from pnote.eu onto Komoot maps",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "https://pnote.eu/*",
    "https://api.space-invaders.com/*"
  ],
  "browser_action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png"
    },
    "default_title": "Pnote Invaders on Komoot",
    "default_popup": "popup/popup.html"
  },
  "background": {
    "scripts": ["background/background.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": ["*://www.komoot.com/*", "*://www.komoot.fr/*", "*://www.komoot.de/*"],
      "js": ["content/content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    "content/inject.js"
  ]
}

